generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DrawingGameLanguage {
  en
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  IGNORED
}

enum BodmasQuestionOperations {
  ADD
  SUB
  MUL
  DIV
}

enum GameStatus {
  WAITING_FOR_PLAYERS
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

enum UserStatus {
  IDOL
  PLAYING
  SEARCHING
}

model User {
  id       String     @id @default(uuid())
  email    String     @unique
  password String
  userName String
  isOnline Boolean    @default(false)
  status   UserStatus @default(IDOL)

  sender   FriendsMapUser[] @relation("user_sender")
  receiver FriendsMapUser[] @relation("user_receiver")

  bodmasGameAnswers  BodmasGameUserAnswer[]
  bodmasGameresults  BodmasGameResult[]
  bodmasGameCreator  BodmasGame[]           @relation("bodmas_creator")
  drawingGameCreator DrawingGame[]          @relation("drawing_creator")
  bodmasGamePlayers  BodmasGamePlayer[]
  drawingGamePlayer  DrawingGamePlayer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BodmasGamePlayer {
  id String @id @default(uuid())

  bodmasGameId String
  bodmasGame   BodmasGame @relation(references: [id], onDelete: Cascade, fields: [bodmasGameId])

  userId String
  user   User   @relation(references: [id], onDelete: Cascade, fields: [userId])

  questionCounter Int @default(0)

  @@unique([bodmasGameId, userId])
}

model BodmasGame {
  id     String     @id @default(uuid())
  status GameStatus @default(WAITING_FOR_PLAYERS)

  createdBy String
  creator   User   @relation("bodmas_creator", onDelete: Cascade, fields: [createdBy], references: [id])

  endTime   DateTime?
  startTime DateTime?

  timeLimit       Int // in seconds
  numberOfPlayers Int

  players BodmasGamePlayer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers   BodmasGameUserAnswer[]
  questions BodmasGameQuestion[]
  results   BodmasGameResult[]
}

model BodmasGameResult {
  id     String     @id @default(uuid())
  gameId String
  userId String
  game   BodmasGame @relation(onDelete: Cascade, fields: [gameId], references: [id])
  user   User       @relation(onDelete: Cascade, fields: [userId], references: [id])

  correctAnswers   Int
  incorrectAnswers Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gameId, userId])
}

model BodmasGameUserAnswer {
  id         String @id @default(uuid())
  gameId     String
  userId     String
  questionId String

  answer     Int
  timeSpent  Int
  isCorrect  Boolean
  answeredAt DateTime?

  game     BodmasGame         @relation(onDelete: Cascade, fields: [gameId], references: [id])
  user     User               @relation(onDelete: Cascade, fields: [userId], references: [id])
  question BodmasGameQuestion @relation(onDelete: Cascade, fields: [questionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gameId, userId, questionId])
}

model BodmasQuestion {
  id String @id @default(uuid())

  operation BodmasQuestionOperations
  operand1  Int
  operand2  Int
  answer    Int
  createdAt DateTime                 @default(now())

  gameQuestions BodmasGameQuestion[]
}

model BodmasGameQuestion {
  id         String    @id @default(uuid())
  gameId     String
  questionId String
  orderIndex Int
  startTime  DateTime? // Date.now() => number

  game     BodmasGame     @relation(onDelete: Cascade, fields: [gameId], references: [id])
  question BodmasQuestion @relation(onDelete: Cascade, fields: [questionId], references: [id])

  userAnswer BodmasGameUserAnswer[]

  @@unique([gameId, questionId])
}

model DrawingGame {
  id String @id @default(uuid())

  createdBy String
  creator   User   @relation("drawing_creator", onDelete: Cascade, fields: [createdBy], references: [id])

  numberOfPlayers Int // limit set by the user while creating game
  language        DrawingGameLanguage @default(en)
  drawTime        Int // limit for drawing in each round
  rounds          Int // total rounds
  status          GameStatus          @default(WAITING_FOR_PLAYERS)

  players DrawingGamePlayer[]
}

model DrawingGamePlayer {
  id String @id @default(uuid())

  userId String
  user   User   @relation(onDelete: Cascade, fields: [userId], references: [id])

  score Int

  drawingGameId String
  drawingGame   DrawingGame @relation(references: [id], onDelete: Cascade, fields: [drawingGameId])
}

model FriendsMapUser {
  id String @id @default(uuid())

  status      FriendRequestStatus @default(PENDING)
  requestedAt DateTime
  respondedAt DateTime?

  senderId String
  sender   User   @relation("user_sender", onDelete: Cascade, fields: [senderId], references: [id])

  receiverId String
  receiver   User   @relation("user_receiver", onDelete: Cascade, fields: [receiverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([receiverId, senderId])
}
