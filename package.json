{
  "name": "games",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "http:be": "cd apps/http-backend && bun start",
    "ws:be": "cd apps/ws-backend && bun start",
    "client:fe": "cd /usr/src/app/apps/client && bun start",
    "build:client": "cd /usr/src/app/apps/client && bun run build",
    "generate:client": "cd /usr/src/app/packages/db && bunx --bun prisma generate",
    "migrate:client": "cd /usr/src/app/packages/db && bunx --bun prisma migrate dev -n 'init'"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
